<mujoco model="g1_inspire scene">
  <include file="g1_inspire.xml"/>

  <statistic center="0 0 1.0" extent="1.2"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0.9 0.9 0.9"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="140" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <!-- Matte white table surface (no specular/reflectance). -->
    <material name="table_white" rgba="0.9 0.9 0.9 1" specular="0.05" shininess="0.05" reflectance="0"/>
  </asset>

  <worldbody>
    <light pos="0 0 3.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- ── Plain white work table (NO objects on it) ───────────────────────────
         Top surface sits at z = 0.75 m to MATCH data_pipeline/stabilize.py
         PLANE_HEIGHT = 0.75 (the plane wrists are mapped onto). Footprint spans
         the pipeline workspace: forward X_NEAR..X_FAR = 0.18..0.55 m and lateral
         Y_SPAN = 0.45 m (±0.225), plus margin, so the hands work over the table
         like in the source video. Static (no joint); collidable surface.
         tabletop: half-thick 0.02 → center z = 0.75 - 0.02 = 0.73. -->
    <body name="work_table" pos="0.42 0 0">
      <geom name="table_top" type="box" size="0.32 0.38 0.02" pos="0 0 0.73"
            material="table_white" contype="1" conaffinity="1"/>
      <geom name="table_leg_fl" type="box" size="0.025 0.025 0.365" pos="0.28 0.34 0.365"
            material="table_white" contype="1" conaffinity="1"/>
      <geom name="table_leg_fr" type="box" size="0.025 0.025 0.365" pos="0.28 -0.34 0.365"
            material="table_white" contype="1" conaffinity="1"/>
      <geom name="table_leg_bl" type="box" size="0.025 0.025 0.365" pos="-0.28 0.34 0.365"
            material="table_white" contype="1" conaffinity="1"/>
      <geom name="table_leg_br" type="box" size="0.025 0.025 0.365" pos="-0.28 -0.34 0.365"
            material="table_white" contype="1" conaffinity="1"/>
    </body>
  </worldbody>
</mujoco>
